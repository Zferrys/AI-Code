<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aicode.mapper.CourseResourceMapper">

    <resultMap id="BaseResultMap" type="com.aicode.entity.CourseResource">
        <id column="id" property="id" />
        <result column="course_id" property="courseId" />
        <result column="title" property="title" />
        <result column="type" property="type" />
        <result column="url" property="url" />
        <result column="description" property="description" />
        <result column="sort_order" property="sortOrder" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <sql id="BaseColumns">
        id, course_id, title, type, url, description, sort_order, create_time
    </sql>

    <select id="selectByCourseId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns" />
        FROM course_resource
        WHERE course_id = #{courseId}
        ORDER BY sort_order ASC, id ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO course_resource (course_id, title, type, url, description, sort_order, create_time)
        VALUES (#{courseId}, #{title}, #{type}, #{url}, #{description}, #{sortOrder}, #{createTime})
    </insert>

    <delete id="deleteById">
        DELETE FROM course_resource WHERE id = #{id}
    </delete>

    <delete id="deleteByCourseId">
        DELETE FROM course_resource WHERE course_id = #{courseId}
    </delete>
</mapper>
