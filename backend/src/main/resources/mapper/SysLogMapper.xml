<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aicode.mapper.SysLogMapper">
    <resultMap id="BaseResultMap" type="com.aicode.entity.SysLog">
        <id column="id" property="id"/><result column="user_id" property="userId"/>
        <result column="action_type" property="actionType"/><result column="target_type" property="targetType"/>
        <result column="target_id" property="targetId"/><result column="description" property="description"/>
        <result column="ip_address" property="ipAddress"/><result column="create_time" property="createTime"/>
    </resultMap>
    <sql id="BaseColumns">id, user_id, action_type, target_type, target_id, description, ip_address, create_time</sql>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_log (user_id, action_type, target_type, target_id, description, ip_address, create_time)
        VALUES (#{userId}, #{actionType}, #{targetType}, #{targetId}, #{description}, #{ipAddress}, #{createTime})
    </insert>
    <select id="selectAllPaged" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM sys_log ORDER BY create_time DESC LIMIT #{offset}, #{limit}
    </select>
    <select id="countAll" resultType="long">SELECT COUNT(*) FROM sys_log</select>
</mapper>
